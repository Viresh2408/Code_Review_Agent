# ══════════════════════════════════════════════════════════════════════════════
#  AI Code Review Agent — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── GitHub App ────────────────────────────────────────────────────────────────
# From your GitHub App settings page (https://github.com/settings/apps/YOUR_APP)
GITHUB_APP_ID=
GITHUB_APP_SLUG=

# Path to the .pem private key file you downloaded from GitHub
# Place it at secrets/github-app.pem (gitignored)
GITHUB_PRIVATE_KEY_PATH=secrets/github-app.pem

# Random secret you set when creating the app — used for HMAC webhook verification
GITHUB_WEBHOOK_SECRET=your-random-webhook-secret-here

# ── Database ──────────────────────────────────────────────────────────────────
# Async SQLAlchemy URL for asyncpg driver
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codereview

# Sync URL for Alembic migrations (alembic doesn't support async natively)
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codereview

POSTGRES_DB=codereview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── LLM APIs ─────────────────────────────────────────────────────────────────
# Anthropic Claude — used for escalation (high-confidence fallback)
ANTHROPIC_API_KEY=sk-ant-...

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# Max inline PR comments before switching to a summary comment (FR-3)
MAX_INLINE_COMMENTS=15

# ── Cost Control ─────────────────────────────────────────────────────────────
# Alert if a single PR review exceeds this cost in USD (NFR-3)
MAX_COST_PER_REVIEW_USD=0.50
